  "keyFeatures": [
    "Type-safe Playwright wrappers for 40+ Vaadin components",
    "Accessibility-first element lookup using ARIA roles",
    "Built-in assertion methods with automatic retry logic",
    "Mixin interfaces for shared component behaviors",
    "Comprehensive test coverage with Spring Boot integration",
    "Shadow DOM piercing and scoped element lookups"
  ],
  "publicApiSurface": [
    "VaadinElement - Base class for all component wrappers",
    "TextFieldElement.getByLabel(page, label) - Find text field by accessible label",
    "ButtonElement.getByText(page, text) - Find button by text content",
    "DialogElement.getByHeaderText(page, text) - Find dialog by header",
    "GridElement.getByCaption(page, caption) - Find grid by caption",
    "element.setValue(value) - Set input field value",
    "element.assertValue(expected) - Assert input value with retry",
    "element.assertVisible() - Assert element visibility",
    "element.assertEnabled() - Assert element is enabled",
    "element.assertRequired() - Assert field is required",
    "element.click() - Click element",
    "element.focus() - Focus element",
    "element.getLocator() - Get underlying Playwright locator",
    "AbstractBasePlaywrightIT - Base test class with Playwright setup",
    "HasInputFieldElement - Mixin for input field operations",
    "HasValidationPropertiesElement - Mixin for validation state",
    "FocusableElement - Mixin for focus operations",
    "HasThemeElement - Mixin for theme variant assertions"
  ]
}
